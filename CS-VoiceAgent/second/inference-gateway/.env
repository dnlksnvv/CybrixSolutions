# =====================================================================
# inference-gateway — example configuration.
# Convention: <MODALITY>_<MODEL>_<FIELD>. One independent block per
# registered model id, so each upstream gets its own credentials.
# =====================================================================

# --- gateway server ---
GATEWAY_ADDR=:8080
GATEWAY_READ_TIMEOUT_MS=60000
GATEWAY_WRITE_TIMEOUT_MS=0
GATEWAY_SHUTDOWN_TIMEOUT_MS=10000
LOG_LEVEL=info

# --- upstream timeouts ---
UPSTREAM_HTTP_TIMEOUT_MS=60000
UPSTREAM_WS_TIMEOUT_MS=30000


# =====================================================================
# LLM
# =====================================================================

# LLM YAML: model-templates/llm/sber/*.yaml и model-templates/llm/qwen/*.yaml
# Пер-вендор: LLM_SBER_TEMPLATE_DIR, LLM_QWEN_TEMPLATE_DIR; или LLM_TEMPLATE_DIR + подпапки sber/ и qwen/.
# Поля upstream — только в YAML; в .env значения секретов по именам из YAML.

# ----- GigaChat / llm/sber (see model-templates/llm/sber/gigachat.yaml) -----
LLM_GIGA_CHAT_CREDENTIALS=MDE5ZGMyNGMtOGFmZC03MzExLWIwNGMtYTYwMzJiYWUyMjgwOjY1ZmZiNWEwLTdjYWUtNDE3ZC05NjJmLTRkNWE3NzJlZjIwZA==

# ----- Qwen LLM (see model-templates/llm/qwen/qwen.yaml) -----
LLM_QWEN_API_KEY=sk-84e7ec698d134fd3a5b757a5530167e3


# =====================================================================
# TTS
# =====================================================================

# ----- TTS: Sber SaluteSpeech (REST) — см. model-templates/tts/sber/*.yaml -----
# Из .env нужен только секрет; scope, urls, voice, format — в YAML (credentials_env ниже).
TTS_SALUTE_CREDENTIALS=MDE5ZGMyMTUtZWU2OC03ODI0LTlmMjYtMzRkNjEyMDRiOThmOmY5MGM4ZWI2LWY3YTUtNGY1MS04ZDQ0LWFkYWIxZjFkZmY3Yg==

# ----- TTS: Qwen realtime (DashScope WebSocket) -----
# Templates: model-templates/tts/qwen-realtime/*.yaml (one profile per file).
# Override path: TTS_QWEN_TEMPLATE_DIR=/abs/or/relative/dir
# From .env only the API key (see api_key_env in each YAML, default TTS_QWEN_API_KEY).
# If the template directory is missing or has no *.yaml, Qwen TTS is not registered.
TTS_QWEN_API_KEY=sk-84e7ec698d134fd3a5b757a5530167e3


# =====================================================================
# STT
# =====================================================================

# Qwen ASR realtime — model-templates/stt/qwen-realtime/*.yaml
# Override: STT_QWEN_TEMPLATE_DIR=...
# From .env only the key named by api_key_env in YAML (default STT_QWEN_REALTIME_API_KEY).
STT_QWEN_REALTIME_API_KEY=sk-84e7ec698d134fd3a5b757a5530167e3
