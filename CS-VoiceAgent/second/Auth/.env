# Logto OSS — copy and set secrets before first `docker compose up`.
# Docs: https://docs.logto.io/logto-oss/deployment-and-configuration

LOGTO_IMAGE_TAG=latest

# Host ports
LOGTO_HTTP_PORT=3003
LOGTO_ADMIN_PORT=3002

# PostgreSQL (must match DB_URL credentials)
PG_USER=logto
PG_PASSWORD=change-me-postgres-password
PG_DB=logto

# Full DSN for Logto (use a URL-safe password or percent-encode special chars)
DB_URL=postgres://logto:change-me-postgres-password@postgres:5432/logto

# Public URLs — used as OIDC issuer base and Admin Console links.
# Local dev:
ENDPOINT=http://localhost:3003
ADMIN_ENDPOINT=http://localhost:3002
# Production (example behind Traefik):
# ENDPOINT=https://auth.example.com
# ADMIN_ENDPOINT=https://auth-admin.example.com
