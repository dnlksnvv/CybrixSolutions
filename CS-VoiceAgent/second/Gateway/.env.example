TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8088
GATEWAY_NETWORK_NAME=cs_gateway

# Host port for jwt-auth (curl /auth/verify from your machine)
JWT_AUTH_HOST_PORT=8000

# --- Machine-to-machine (your backend only; Traefik does not use these) ---
# Create an M2M app in Logto, grant Logto Management API scopes, call token endpoint from server.
LOGTO_M2M_CLIENT_ID=
LOGTO_M2M_CLIENT_SECRET=
LOGTO_MANAGEMENT_API_RESOURCE=https://w93wb3.logto.app/api

# Your Logto tenant issuer URL, for example:
# https://your-tenant.logto.app/oidc
LOGTO_ISSUER=https://w93wb3.logto.app/oidc

# Optional override. Leave empty to auto-derive from LOGTO_ISSUER + /jwks
LOGTO_JWKS_URI=https://w93wb3.logto.app/oidc/jwks

# Optional JWT signing alg allow-list (comma-delimited).
# Logto Cloud often uses ES384.
# Example: ES384,RS256
JWT_ALLOWED_ALGS=ES384,RS256

# API audience configured in Logto for your backend resource
# Example: https://api.cybrix.local
LOGTO_AUDIENCE=https://api.cybrix.local

# Prefix of JWT `aud` for organization-scoped tokens from getOrganizationToken(orgId).
# aud must be "<prefix><org_id>" and match claim organization_id / org_id. Example:
#   urn:logto:organization:
LOGTO_ORGANIZATION_AUDIENCE_PREFIX=urn:logto:organization:

# Optional, space-delimited scopes required for protected routes (API-resource JWTs only).
# Organization tokens (aud urn:logto:organization:<id>) use org permissions in scope, not
# these API scopes — jwt-auth skips this check for org-audience tokens so org flows work.
# Example: api:read api:write
REQUIRED_SCOPES=api:read

# --- Cloudflare Tunnel (optional) ---
# Zero Trust → Networks → Connectors → tunnel → Docker → copy token into:
CLOUDFLARE_TUNNEL_TOKEN=
#
# Published application route → Service (origin) URL must resolve FROM THE CLOUDFLARED
# process. With cloudflared in this compose file (network cs_gateway), use:
#   http://cs-gateway-traefik:80   (Traefik container_name — most reliable)
#   or http://traefik:80           (Compose service name)
# If cloudflared runs on the host OS instead, use http://127.0.0.1:80 (or your mapped host port).
# Do NOT use http://traefik:80 on the host — that name exists only inside Docker.
#
# Debug 404: https://<public-hostname>/ping should return 200 (Traefik ping). Catch-all 404
# here means the origin URL is wrong or cloudflared is not on cs_gateway. If /ping is 200
# but /workspaces is 404, Traefik has no backend router (deploy WorkspacesService on this host).
#
# cloudflared is behind compose profile "cloudflare". Start it either:
#   docker compose --profile cloudflare up -d
# or enable the profile via this file (Compose reads it):
# COMPOSE_PROFILES=cloudflare
#
# If the tunnel retries with "quic: handshake did not complete in time", keep default http2 or set:
# CLOUDFLARE_TUNNEL_PROTOCOL=http2
# To try QUIC again: CLOUDFLARE_TUNNEL_PROTOCOL=quic
CLOUDFLARE_TUNNEL_PROTOCOL=http2

