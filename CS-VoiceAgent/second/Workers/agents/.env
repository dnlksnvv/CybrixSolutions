# Файл в .gitignore — не коммить.
# Workers разговаривают только с inference-gateway. Все upstream URL/ключи живут в .env шлюза.

# LiveKit (локально: подними сервер или поменяй на wss://… из cloud.livekit.io)
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Inference Gateway
INFERENCE_GATEWAY_URL=http://127.0.0.1:8080

# LLM (id из реестра шлюза, см. inference-gateway/.env)
LLM_MODEL=giga-chat
# Альтернативы: qwen-llm

# STT
STT_MODEL=salute-stt
STT_LANGUAGE=ru
STT_SAMPLE_RATE=16000

# TTS
#TTS_MODEL=qwen-tts-vc
#TTS_VOICE=qwen-tts-vc-boris-voice-20260426152144085-6316
TTS_MODEL=salute
TTS_VOICE=Bys_24000
# Альтернативные голоса для qwen-tts-flash: Cherry, Aiden
# Для qwen-tts-vc: TTS_MODEL=qwen-tts-vc, TTS_VOICE=qwen-tts-vc-vova-…
#TTS_MODEL=qwen-tts-flash
#TTS_VOICE=Ryan


TTS_LANGUAGE_TYPE=Auto
TTS_SAMPLE_RATE=24000
# TTS_MODE: commit | server_commit | пусто (берётся из .env шлюза).
# Для passthrough ниже сами проставим server_commit на стороне Workers.
TTS_MODE=server_commit
# Преэмптивная генерация (LiveKit): LLM/TTS стартуют до подтверждения конца хода.
ALIYUN_PREEMPTIVE_GENERATION=1
ALIYUN_PREEMPTIVE_TTS=1

# Сравнение текста преемптива с финалом: lower, убрать .,!?:; и все пробелы (иначе partial без «.» не матчится с final).
PREEMPTIVE_TRANSCRIPT_NORMALIZE=1
# Лог проверки преемптива: сырой/нормализованный текст, match, при отказе — chat_ctx/tools/tool_choice.
PREEMPTIVE_TRANSCRIPT_MATCH_LOG=1
# Почему on_preemptive_generation не стартовал LLM: SKIP с reason + wall_ts/mono_ts; START при успехе.
PREEMPTIVE_GENERATION_HOOK_LOG=1

# TTS: как слать текст в Qwen realtime
# 0 / false / пусто — буфер до границ предложения (StreamingSentencizer + mode=commit): лучше интонация и «эмоция», чуть выше TTFA.
# 1 / true — passthrough: каждый токен LLM сразу в TTS (server_commit): минимальная задержка, голос часто ровнее/безэмоциональнее. В qwen генерация идёт моментально по мере прихода
ALIYUN_TTS_PASSTHROUGH=0

# TTS: gated TTS: budget + fixed extra delay - В случае, если включен razdel - то ответ делится на предложения, которые отправляются в tts только после того, откроется гейт. Гейт откроется через время = время текущего чанка - budget + extra_delay. Время начинает считаться с момента первого чанка.
# Если budget = 0, то гейт откроется после воспроизведения всего звука предложения.
TTS_GATE_GENERATION_BUDGET_MS=0
# Extra delay - дополнительная задержка в миллисекундах, которая будет добавлена к задержке (длительности звука - budget)
TTS_GATE_EXTRA_DELAY_MS=0

# Трейс на дашборд (Workers-3/dashboard). Запусти uvicorn на этом порту или поменяй URL.
CYBRIX_TRACE_URL=http://127.0.0.1:8010
