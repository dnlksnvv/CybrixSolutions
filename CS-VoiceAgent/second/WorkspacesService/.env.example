HTTP_ADDR=:8080
LOG_LEVEL=info
SHUTDOWN_TIMEOUT=10s

# OIDC issuer of the Logto tenant. Used to derive token endpoint when
# LOGTO_TOKEN_ENDPOINT is empty (issuer + "/token").
LOGTO_ISSUER=https://w93wb3.logto.app/oidc
LOGTO_TOKEN_ENDPOINT=

# Logto tenant id (same as the subdomain on *.logto.app). Optional if
# LOGTO_MANAGEMENT_BASE_URL is https://{tenant}.logto.app — then it is derived.
# LOGTO_TENANT_ID=w93wb3

# Base URL for Logto Management API calls (no trailing slash).
LOGTO_MANAGEMENT_BASE_URL=https://w93wb3.logto.app
# Built-in Management API resource indicator (audience for the M2M token).
LOGTO_MANAGEMENT_RESOURCE=https://w93wb3.logto.app/api

# M2M application credentials.
# App ID of the Logto Machine-to-Machine application.
LOGTO_M2M_CLIENT_ID=zh6mq3lp7ny96ouwsllsh
# Long-lived App Secret. Generate it in Logto Console:
#   Applications -> WorkspacesService M2M -> Endpoints & Credentials -> App Secret
# NEVER commit the real value, keep it only in the local .env or a secrets manager.
LOGTO_M2M_CLIENT_SECRET=
LOGTO_M2M_SCOPE=all
LOGTO_HTTP_TIMEOUT=5s

# Name of the Logto organization role granted to the workspace creator.
# Must exist as an Organization Role in Logto and have permissions you need.
WORKSPACE_OWNER_ROLE=Owner

# SPA URL prefix for invitation email links (optional). If unset, the service still starts;
# POST invite / resend return 503 until you configure this.
# Example: https://your-spa/invitations -> email links .../invitations/<id>
INVITATION_LINK_BASE_URL=https://app.cybrix.local/invitations
