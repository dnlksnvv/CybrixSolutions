# ---------------------------------------------------------------------------
# Это НЕ URL твоего FastAPI и НЕ Alibaba. Здесь только подключение к серверу
# LiveKit (WebRTC / «комнаты»). Он может крутиться у тебя на машине в Docker.
# ---------------------------------------------------------------------------

# --- Вариант А: только локально (Docker из ../Server/docker-compose.yml) ---
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=ws://127.0.0.1:7880

# --- Вариант Б: облако LiveKit (если когда-нибудь понадобится) ---
# LIVEKIT_API_KEY=...
# LIVEKIT_API_SECRET=...
# LIVEKIT_URL=wss://xxxx.livekit.cloud

# Agent dispatch (https://docs.livekit.io/agents/server/agent-dispatch)
# Пусто = автоматический dispatch к воркеру `python agent.py dev`
AGENT_NAME=

# Обычно пусто для локальной разработки
NEXT_PUBLIC_APP_CONFIG_ENDPOINT=
SANDBOX_ID=
